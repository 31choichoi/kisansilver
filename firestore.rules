rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Dynamic helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == '31choichoi@gmail.com' // Bootstrapped admin from request
      );
    }

    function isValidPost(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() <= 200 &&
             data.content is string && data.content.size() > 0 &&
             data.category in ['notice', 'community', 'diet', 'activity'] &&
             data.createdAt is timestamp;
    }

    match /posts/{postId} {
      allow read: if true; // Public can read posts
      allow create: if isAdmin() && isValidPost(request.resource.data) && 
                      request.resource.data.createdAt == request.time;
      allow update: if isAdmin() && isValidPost(request.resource.data) &&
                      request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isAdmin();
    }

    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false; // Only manageable via console or specialized tool
    }
  }
}
